{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"security": {
				"noDangerouslySetInnerHtml": "off"
			},
			"suspicious": {
				"noArrayIndexKey": "off"
			},
			"a11y": {
				"noNoninteractiveTabindex": "off",
				"noStaticElementInteractions": "off",
				"useSemanticElements": "off"
			}
		}
	},
	"files": {
		"includes": ["**", "!specs", "!dist", "!.claude"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	}
}
